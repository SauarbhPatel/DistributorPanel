{
  "expo": {
    "name": "Distributor Panel",
    "slug": "ecommerce_baofeng_radios",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/playstore-icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
